# ============================================================
#  Twenty CRM v2.14.0 — .env  ·  riparasubito.tech
#  Copia in .env e compila i segreti. NON committare .env reale.
# ============================================================

# ── App ──────────────────────────────────────────────
SERVER_URL=https://crm.riparasubito.tech
# Genera con: openssl rand -base64 32
APP_SECRET=CHANGE_ME_openssl_rand_base64_32
NODE_PORT=3000

# ── PostgreSQL 16 (container twenty-db) ─────────────
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=CHANGE_ME_strong_password
PG_DATABASE_NAME=default
# URL completo (deve combaciare con i 3 valori sopra)
PG_DATABASE_URL=postgres://twenty:CHANGE_ME_strong_password@twenty-db:5432/default

# ── Redis 7 (container twenty-redis) ────────────────
REDIS_URL=redis://twenty-redis:6379

# ── Storage allegati — Wasabi (S3-compatible) ───────
STORAGE_TYPE=s3
STORAGE_S3_REGION=eu-central-2
STORAGE_S3_NAME=riparasubito-twenty-attachments
STORAGE_S3_ENDPOINT=https://s3.eu-central-2.wasabisys.com
STORAGE_S3_ACCESS_KEY_ID=CHANGE_ME_wasabi_key
STORAGE_S3_SECRET_ACCESS_KEY=CHANGE_ME_wasabi_secret

# ── Email / Mail connector (WF auto-capture + notifiche) ──
EMAIL_DRIVER=smtp
EMAIL_FROM_ADDRESS=info@riparasubito.tech
EMAIL_FROM_NAME=RiparaSubito
EMAIL_SMTP_HOST=CHANGE_ME_smtp_host
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=CHANGE_ME_smtp_user
EMAIL_SMTP_PASSWORD=CHANGE_ME_smtp_password

# ── Messaging sync (opzionale, per auto-capture via Gmail) ──
MESSAGING_PROVIDER_GMAIL_ENABLED=false

# ── Backup → Wasabi (usato da scripts/backup.sh) ────
BACKUP_S3_BUCKET=riparasubito-twenty-backups
BACKUP_RETENTION_DAYS=14
